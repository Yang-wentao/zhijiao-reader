{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "types": [
      "node",
      "vite/client"
    ]
  },
  "include": [
    "vite.config.ts",
    "server/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
