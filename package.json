{
  "name": "codex-paper-reader",
  "private": true,
  "version": "0.1.0",
  "description": "Local PDF paper reader with translation and assistant panel support.",
  "author": "Yang Wentao",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "check": "node scripts/launch.mjs --check",
    "configure": "node scripts/launch.mjs --configure-only",
    "release:zip": "node scripts/create-release.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "launch": "node scripts/launch.mjs",
    "build": "tsc -b && vite build",
    "electron:dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://127.0.0.1:5173 http://127.0.0.1:8787 && electron electron/main.mjs\"",
    "electron:pack": "npm run build && npm run build:server && electron-builder --config electron-builder.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/search": "^3.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "katex": "^0.16.45",
    "openai": "^6.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.0.1",
    "playwright": "^1.59.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  }
}
